---
const year = new Date().getFullYear();
const sourceUrl = 'https://github.com/lbaker2/me';
const linkClass =
  'underline decoration-slate-300 underline-offset-2 hover:text-slate-700 dark:decoration-slate-600 dark:hover:text-slate-200';

const navItems = [
  { label: 'Approach', href: '/#approach' },
  { label: 'Work', href: '/#work' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Contact', href: '/#contact' },
];
---

<footer class="border-t border-slate-200 dark:border-slate-800">
  <div class="mx-auto max-w-3xl px-6 py-8 text-sm text-slate-500 dark:text-slate-400">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <nav aria-label="Footer">
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="transition-colors hover:text-slate-900 dark:hover:text-slate-100"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <a
        href="#top"
        class="inline-flex items-center gap-1 transition-colors hover:text-slate-900 dark:hover:text-slate-100"
      >
        Back to top <span aria-hidden="true">&uarr;</span>
      </a>
    </div>

    <p class="mt-6 text-xs">
      &copy; {year} Lawrence Baker. Built with{' '}
      <a href="https://astro.build" class={linkClass} rel="noopener noreferrer" target="_blank"
        >Astro</a
      >,{' '}
      <a href="https://tailwindcss.com" class={linkClass} rel="noopener noreferrer" target="_blank"
        >Tailwind CSS</a
      >, and a good deal of AI pair-programming. The{' '}
      <a href={sourceUrl} class={linkClass} rel="noopener noreferrer" target="_blank">source</a>{
        ' '
      }is on GitHub, and the resume lives in a single data file.
    </p>
  </div>
</footer>
