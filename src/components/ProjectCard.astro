---
import type { Project } from '../data/resume';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { slug, title, summary, context, tech } = project;
---

<article
  class="group rounded-lg border border-slate-200 p-6 transition-colors hover:border-slate-300 dark:border-slate-800 dark:hover:border-slate-700"
>
  <p class="text-xs font-medium uppercase tracking-widest text-slate-400">{context}</p>
  <h3 class="mt-2 text-lg font-semibold text-slate-900 dark:text-slate-100">
    <a
      href={`/projects/${slug}`}
      class="underline decoration-slate-300 underline-offset-4 transition-colors hover:decoration-sky-500 dark:decoration-slate-600 dark:hover:decoration-sky-400"
    >
      {title}
    </a>
  </h3>
  <p class="mt-2 text-slate-600 dark:text-slate-300">{summary}</p>

  {
    tech && tech.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
        {tech.map((item) => (
          <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
            {item}
          </li>
        ))}
      </ul>
    )
  }

  <p class="mt-4 text-sm">
    <a
      href={`/projects/${slug}`}
      class="font-medium text-sky-600 transition-colors hover:text-sky-500 dark:text-sky-400"
    >
      Read the case study <span aria-hidden="true">&rarr;</span>
    </a>
  </p>
</article>
