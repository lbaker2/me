---
import type { Experience } from '../data/resume';

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
const { company, role, startDate, endDate, location, summary, highlights, tech } = experience;
---

<article class="relative border-l border-slate-200 pl-6 dark:border-slate-800">
  <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-sky-500" aria-hidden="true"
  ></span>

  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
      {role}
      <span class="font-normal text-slate-500 dark:text-slate-400">· {company}</span>
    </h3>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      <time>{startDate}</time> &ndash; <time>{endDate}</time>
      {location && <span class="ml-1">· {location}</span>}
    </p>
  </div>

  <p class="mt-2 text-slate-600 dark:text-slate-300">{summary}</p>

  <ul
    class="mt-3 list-disc space-y-1.5 pl-5 text-slate-600 marker:text-slate-400 dark:text-slate-300"
  >
    {highlights.map((highlight) => <li>{highlight}</li>)}
  </ul>

  {
    tech && tech.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
        {tech.map((item) => (
          <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
            {item}
          </li>
        ))}
      </ul>
    )
  }
</article>
