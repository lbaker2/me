---
import type { OpenSourceProject } from '../data/resume';

interface Props {
  project: OpenSourceProject;
}

const { project } = Astro.props;
const { name, description, repo, demo, links, tech } = project;

const linkClass = 'font-medium text-sky-600 transition-colors hover:text-sky-500 dark:text-sky-400';
---

<article>
  <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">{name}</h3>
  <p class="mt-2 max-w-prose text-slate-600 dark:text-slate-300">{description}</p>

  {
    tech && tech.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies used">
        {tech.map((item) => (
          <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
            {item}
          </li>
        ))}
      </ul>
    )
  }

  <p class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
    <a href={repo} class={linkClass} rel="noopener noreferrer" target="_blank">
      Source <span aria-hidden="true">&rarr;</span>
    </a>
    {
      demo && (
        <a href={demo} class={linkClass} rel="noopener noreferrer" target="_blank">
          Live demo <span aria-hidden="true">&rarr;</span>
        </a>
      )
    }
    {
      links?.map((link) => (
        <span class="inline-flex items-center gap-2">
          <a href={link.href} class={linkClass} rel="noopener noreferrer" target="_blank">
            {link.label} <span aria-hidden="true">&rarr;</span>
          </a>
          {link.note && <span class="text-slate-400 dark:text-slate-500">({link.note})</span>}
        </span>
      ))
    }
  </p>
</article>
