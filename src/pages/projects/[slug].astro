---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { resume } from '../../data/resume';

export const getStaticPaths = (() => {
  return resume.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { title, summary, context, problem, approach, outcome, metrics, tech } = project;

const pageTitle = `${title} · ${resume.profile.name}`;

const sections = [
  { heading: 'The problem', body: problem },
  { heading: 'The approach', body: approach },
  { heading: 'The outcome', body: outcome },
];
---

<BaseLayout title={pageTitle} description={summary}>
  <Nav />

  <main id="main" class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <a
      href="/#work"
      class="text-sm font-medium text-sky-600 transition-colors hover:text-sky-500 dark:text-sky-400"
    >
      <span aria-hidden="true">&larr;</span> Back to selected work
    </a>

    <header class="mt-6">
      <p class="text-xs font-medium uppercase tracking-widest text-slate-400">{context}</p>
      <h1
        class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100"
      >
        {title}
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">{summary}</p>
    </header>

    {
      metrics && metrics.length > 0 && (
        <dl class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {metrics.map((metric) => (
            <div class="rounded-lg border border-slate-200 p-4 dark:border-slate-800">
              <dd class="text-sm font-medium text-slate-700 dark:text-slate-200">{metric}</dd>
            </div>
          ))}
        </dl>
      )
    }

    <div class="mt-12 space-y-10">
      {
        sections.map((section) => (
          <section>
            <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
              {section.heading}
            </h2>
            <p class="mt-3 max-w-prose leading-relaxed text-slate-600 dark:text-slate-300">
              {section.body}
            </p>
          </section>
        ))
      }
    </div>

    {
      tech && tech.length > 0 && (
        <div class="mt-12">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
            Built with
          </h2>
          <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies used">
            {tech.map((item) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </main>

  <Footer />
</BaseLayout>
