---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import OpenSourceItem from '../components/OpenSourceItem.astro';
import { resume } from '../data/resume';

const { profile, experience, projects, openSource, skills, education, certifications, contact } =
  resume;

const pageTitle = `${profile.name} · ${profile.title}`;
---

<BaseLayout title={pageTitle} description={profile.tagline}>
  <span id="top" class="sr-only"></span>
  <Nav />

  <main id="main" class="mx-auto max-w-3xl px-6">
    <!-- Hero / Profile -->
    <section class="py-16 sm:py-24" aria-labelledby="profile-heading">
      <p class="text-sm font-medium uppercase tracking-widest text-sky-600 dark:text-sky-400">
        {profile.title}
      </p>
      <h1
        id="profile-heading"
        class="mt-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-slate-100"
      >
        {profile.name}
      </h1>
      <p class="mt-4 text-xl text-slate-600 dark:text-slate-300">
        {profile.tagline}
      </p>
      <p class="mt-6 max-w-prose leading-relaxed text-slate-600 dark:text-slate-300">
        {profile.about}
      </p>
      <div
        class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-slate-500 dark:text-slate-400"
      >
        <span
          class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800"
        >
          <span class="h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
          {profile.availability}
        </span>
        <span>{profile.location}</span>
      </div>
    </section>

    <!-- Selected Work -->
    <Section id="work" title="Selected Work">
      <div class="grid gap-6 sm:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Section>

    <!-- Open Source -->
    <Section id="open-source" title="Open Source">
      <div class="space-y-10">
        {openSource.map((project) => <OpenSourceItem project={project} />)}
      </div>
    </Section>

    <!-- Experience -->
    <Section id="experience" title="Experience">
      <div class="space-y-10">
        {experience.map((item) => <ExperienceItem experience={item} />)}
      </div>
    </Section>

    <!-- Skills -->
    <Section id="skills" title="Skills">
      <dl class="grid gap-8 sm:grid-cols-2">
        {
          skills.map((group) => (
            <div>
              <dt class="font-semibold text-slate-900 dark:text-slate-100">{group.category}</dt>
              <dd class="mt-2">
                <ul class="flex flex-wrap gap-2">
                  {group.items.map((item) => (
                    <li class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                      {item}
                    </li>
                  ))}
                </ul>
              </dd>
            </div>
          ))
        }
      </dl>
    </Section>

    <!-- Certifications -->
    {
      certifications.length > 0 && (
        <Section id="certifications" title="Certifications">
          <ul class="space-y-3">
            {certifications.map((cert) => (
              <li class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between">
                <span class="text-slate-900 dark:text-slate-100">
                  {cert.href ? (
                    <a
                      href={cert.href}
                      class="underline decoration-slate-300 underline-offset-4 transition-colors hover:decoration-sky-500 dark:decoration-slate-600 dark:hover:decoration-sky-400"
                      rel="noopener noreferrer"
                    >
                      {cert.name}
                    </a>
                  ) : (
                    cert.name
                  )}
                  {cert.issuer && (
                    <span class="text-slate-500 dark:text-slate-400"> · {cert.issuer}</span>
                  )}
                </span>
                {cert.year && (
                  <span class="text-sm text-slate-500 dark:text-slate-400">{cert.year}</span>
                )}
              </li>
            ))}
          </ul>
        </Section>
      )
    }

    <!-- Education -->
    <Section id="education" title="Education">
      <div class="space-y-8">
        {
          education.map((entry) => (
            <article>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                  {entry.qualification}
                  <span class="font-normal text-slate-500 dark:text-slate-400">
                    · {entry.institution}
                  </span>
                </h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  <time>{entry.startDate}</time> &ndash; <time>{entry.endDate}</time>
                  {entry.location && <span class="ml-1">· {entry.location}</span>}
                </p>
              </div>
              {entry.detail && (
                <p class="mt-2 text-slate-600 dark:text-slate-300">{entry.detail}</p>
              )}
            </article>
          ))
        }
      </div>
    </Section>

    <!-- Contact -->
    <Section id="contact" title="Contact">
      <p class="max-w-prose text-slate-600 dark:text-slate-300">
        If you are hiring, building something interesting, or just want to compare notes, I would be
        glad to hear from you.
      </p>
      <ul class="mt-6 flex flex-wrap gap-x-8 gap-y-3">
        {
          contact.map((link) => (
            <li>
              <a
                href={link.href}
                class="group inline-flex items-center gap-2 text-slate-900 underline decoration-slate-300 underline-offset-4 transition-colors hover:decoration-sky-500 dark:text-slate-100 dark:decoration-slate-600 dark:hover:decoration-sky-400"
                rel="noopener noreferrer"
              >
                <span class="text-xs font-semibold uppercase tracking-widest text-slate-400 group-hover:text-sky-500 dark:group-hover:text-sky-400">
                  {link.label}
                </span>
                <span>{link.display ?? link.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </Section>
  </main>

  <Footer />
</BaseLayout>
